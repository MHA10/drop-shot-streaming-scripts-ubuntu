# Server Configuration
BASE_URL=https://api.drop-shot.live
# BASE_URL=http://192.168.10.5:3001

# images path
CLIENT_IMAGES_PATH=./public/client.png

# SSE Configuration
SSE_RETRY_INTERVAL=5000
SSE_MAX_RETRIES=100000

# Stream Configuration
PERSISTENT_STATE_DIR=/var/tmp/stream_registry
TEMP_STATE_DIR=/tmp/stream_registry
HEALTH_CHECK_INTERVAL=30000

# FFmpeg Configuration
RTSP_INPUT_PARAMS=-rtsp_transport tcp
OUTPUT_PARAMS_VIDEO=-c:v libx264 -preset veryfast -b:v 4500k -maxrate 5000k -bufsize 10000k -vf scale=1920:1080 -f flv
OUTPUT_PARAMS_AUDIO=-c:a aac -b:a 128k -ar 44100

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/stream_manager.log

# Ground info
GROUND_ID=385136f6-7cf0-4e7f-b601-fea90079c227

# Remote Logging Configuration
REMOTE_LOGGING_ENABLED=true
REMOTE_LOGGING_SOURCE_ID=streamer-node-pi-001
REMOTE_LOGGING_BATCH_SIZE=50
REMOTE_LOGGING_BATCH_INTERVAL=3000
REMOTE_LOGGING_MAX_MEMORY_USAGE=512000
REMOTE_LOGGING_RETRY_ATTEMPTS=3
REMOTE_LOGGING_RETRY_DELAY=1000

# Development
NODE_ENV=development

# Supabase Configuration (Optional - for real-time features)
# Enable/disable Supabase real-time listener
SUPABASE_ENABLED=false

# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Table and channel configuration
# Table to listen for changes (default: score_board)
SUPABASE_TABLE_NAME=score_board

# Channel name for the subscription (default: score_board-channel)
SUPABASE_CHANNEL_NAME=score_board-channel

# Cloudinary Configuration (For dynamic padel ground logos)
REACT_APP_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
